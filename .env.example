# Artalk Comments (optional)
# Defined in `astro.config.mjs`
# Leave PUBLIC_ARTALK_ENABLED unset to auto-enable when PUBLIC_ARTALK_SERVER is provided
# PUBLIC_ARTALK_ENABLED=true
# PUBLIC_ARTALK_SERVER=https://comments.example.com

# Umami Analytics (optional)
# Defined in `astro.config.mjs`
# UMAMI_URL=https://your-umami-instance.com/script.js
# UMAMI_WEBSITE_ID=your-website-id
