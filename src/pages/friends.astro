---
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Comments from "@/components/blocks/Comments.astro";
import Toast from "@/components/blocks/Toast.astro";
import site from "@/config/site";

const friends = (await getCollection("friends")).sort(
  (a, b) => a.data.order - b.data.order,
);
const emailContact = site.social.find((item) =>
  item.href.startsWith("mailto:"),
);

const myInfo = {
  name: site.friendCard.name,
  description: site.friendCard.description,
  link: (site.friendCard.link || Astro.site || Astro.url.origin).toString(),
  avatar: site.friendCard.avatar || site.meta.logo,
};

const avatarUrl =
  myInfo.avatar.startsWith("http://") || myInfo.avatar.startsWith("https://")
    ? myInfo.avatar
    : new URL(myInfo.avatar, myInfo.link).toString();
---

<Layout
  title={site.labels.friendsTitle}
  description={site.labels.friendsDescription}
>
  <div class="animate-in fade-in slide-in-from-bottom-4 mx-auto max-w-2xl p-8 duration-700 md:p-16">
    <section class="mb-24">
      <header class="mb-12">
        <h2 class="mb-4 text-3xl font-bold">{site.labels.friendsTitle}</h2>
        <p class="mb-12 text-sm font-light text-muted-foreground italic">
          {site.labels.friendsDescription}
        </p>
      </header>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {friends.length === 0 ? (
          <div class="col-span-full py-12 text-center">
            <p class="text-sm text-muted-foreground">No friends yet.</p>
          </div>
        ) : (
          friends.map((friend) => (
            <a
              href={friend.data.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-5 rounded-2xl border border-border/40 p-4 hover:bg-muted/30"
            >
              <Image
                src={friend.data.avatar}
                width={48}
                height={48}
                alt={friend.data.name}
                loading={"lazy"}
                class="rounded-xl bg-muted transition-transform duration-300 group-hover:rotate-6 group-hover:scale-110"
              />
              <div class="flex flex-col">
                <span class="text-sm font-bold text-foreground/80 group-hover:text-primary">
                  {friend.data.name}
                </span>
                <span class="line-clamp-1 text-[11px] text-muted-foreground">
                  {friend.data.description}
                </span>
              </div>
            </a>
          ))
        )}
      </div>

      <div class="mt-12 border-t border-border/40 pt-8">
        <p class="mb-6 text-sm leading-relaxed font-light text-muted-foreground">
          Below is my site info. If you write a blog too, feel free to say hi.
          {
            emailContact ? (
              <>
                {" "}
                You can also
                <a
                  href={emailContact.href}
                  class="mx-1 border-b border-border pb-0.5 text-foreground/80 transition-colors hover:border-primary hover:text-primary"
                >
                  send an email
                </a>
                if you prefer.
              </>
            ) : null
          }
        </p>

        <div class="rounded-2xl border border-border/40 p-5">
          <div class="mb-5 flex items-center gap-4">
            <img
              src={avatarUrl}
              width="52"
              height="52"
              alt={myInfo.name}
              loading="lazy"
              class="rounded-xl bg-muted object-cover"
            />
            <div class="min-w-0">
              <h3 class="text-base font-bold text-foreground/85">
                {myInfo.name}
              </h3>
              <p class="text-sm text-muted-foreground">{myInfo.description}</p>
            </div>
          </div>

          <div class="space-y-3 text-sm">
            <p class="flex flex-col gap-1 sm:flex-row sm:gap-3">
              <span class="w-18 shrink-0 text-muted-foreground">Name</span>
              <span>{myInfo.name}</span>
            </p>
            <p class="flex flex-col gap-1 sm:flex-row sm:gap-3">
              <span class="w-18 shrink-0 text-muted-foreground">Link</span>
              <a
                href={myInfo.link}
                class="break-all text-foreground/80 transition-colors hover:text-primary"
              >
                {myInfo.link}
              </a>
            </p>
            <p class="flex flex-col gap-1 sm:flex-row sm:gap-3">
              <span class="w-18 shrink-0 text-muted-foreground">Description</span>
              <span>{myInfo.description}</span>
            </p>
            <p class="flex flex-col gap-1 sm:flex-row sm:gap-3">
              <span class="w-18 shrink-0 text-muted-foreground">Avatar</span>
              <a
                href={avatarUrl}
                class="break-all text-foreground/80 transition-colors hover:text-primary"
              >
                {avatarUrl}
              </a>
            </p>
          </div>
        </div>
      </div>

      <div class="mt-12 border-t border-border/40 pt-8">
        <h3 class="mb-3 text-base font-bold text-foreground/85">Leave a note</h3>
        <p class="mb-6 text-sm font-light text-muted-foreground">
          If you want to swap links or just chat, you can leave a comment below.
        </p>

        <Toast />
        <Comments />
      </div>
    </section>
  </div>
</Layout>
