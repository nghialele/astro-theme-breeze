---
import site from "@/config/site";

const { enabled, provider, artalk } = site.comments;
const artalkEnabled = enabled && provider === "artalk" && artalk;
---

{
  artalkEnabled && (
    <div class="animate-in fade-in duration-1000">
      <div
        id="atk-comments"
        data-server={artalk.server}
        data-site-name={site.meta.title}
        data-success-message={site.labels.commentSuccess}
      />
    </div>
  )
}

<script>
  async function setupComments() {
    const el = document.querySelector("#atk-comments");
    if (!(el instanceof HTMLElement)) return;
    if (el.dataset.loaded === "true") return;

    el.dataset.loaded = "true";

    const server = el.dataset.server;
    const siteName = el.dataset.siteName;
    const successMessage = el.dataset.successMessage;
    if (!server) return;

    const [{ default: Artalk }] = await Promise.all([
      import("artalk"),
      import("artalk/dist/Artalk.css"),
    ]);

    const artalk = Artalk.init({
      el: "#atk-comments",
      server,
      site: siteName || document.title,
      pageTitle: document.title,
      pageKey: document.location.pathname,
    });

    artalk.on("comment-inserted", function () {
      const showToast = window.showToast;
      if (typeof showToast === "function" && successMessage) {
        showToast(successMessage, "success");
      }
    });
  }

  document.addEventListener("astro:page-load", () => {
    void setupComments();
  });

  if (document.readyState !== "loading") {
    void setupComments();
  } else {
    document.addEventListener("DOMContentLoaded", () => {
      void setupComments();
    });
  }
</script>

<style is:global>
  .artalk,
  .atk-layer-wrap {
    --at-color-main: var(--primary) !important;
    --at-color-primary: var(--primary) !important;

    --at-color-font: var(--foreground) !important;
    --at-color-deep: var(--foreground) !important;
    --at-color-sub: var(--muted-foreground) !important;
    --at-color-grey: var(--muted-foreground) !important;
    --at-color-meta: var(--muted-foreground) !important;

    --at-color-border: var(--border) !important;
    --at-color-bg: var(--card) !important;
    --at-color-bg-transl: oklch(from var(--card) l c h / 0.95) !important;
    --at-color-bg-grey: oklch(from var(--muted) l c h / 0.1) !important;
    --at-color-bg-grey-transl: oklch(from var(--muted) l c h / 0.05) !important;
    --at-color-bg-light: oklch(from var(--primary) l c h / 0.05) !important;

    --at-color-gradient: linear-gradient(
      180deg,
      transparent,
      var(--card)
    ) !important;
  }

  .dark .artalk,
  .dark .atk-layer-wrap {
    --at-color-bg: var(--card) !important;
    --at-color-bg-transl: oklch(from var(--card) l c h / 0.95) !important;
    --at-color-bg-grey: oklch(from var(--muted) l c h / 0.3) !important;

    --at-color-gradient: linear-gradient(
      180deg,
      transparent,
      var(--background)
    ) !important;
  }

  .atk-main-editor {
    border-radius: 1.5rem !important;
    overflow: hidden;
  }

  .atk-main-editor:focus-within {
    box-shadow: 0 0 0 2px oklch(from var(--primary) l c h / 0.15) !important;
  }

  .artalk > .atk-list > .atk-list-header {
    padding: 0 0 1rem !important;
    margin-bottom: 1rem !important;
    border-bottom: 1px solid oklch(from var(--border) l c h / 0.4) !important;
  }

  .atk-comment-wrap {
    border-bottom: 1px solid oklch(from var(--border) l c h / 0.35) !important;
    padding: 0.25rem 0 !important;
  }

  .atk-comment {
    padding: 1rem 0.25rem !important;
  }

  .atk-comment > .atk-avatar img {
    border-radius: 0.9rem !important;
    background: var(--muted) !important;
  }

  .atk-comment > .atk-main > .atk-header .atk-item.atk-nick,
  .atk-comment > .atk-main > .atk-header .atk-item.atk-nick a {
    font-size: 0.95rem !important;
    font-weight: 700 !important;
    color: var(--foreground) !important;
  }

  .atk-comment > .atk-main > .atk-header .atk-item {
    color: var(--muted-foreground) !important;
  }

  .atk-comment > .atk-main > .atk-body > .atk-content {
    color: var(--foreground) !important;
    line-height: 1.8 !important;
  }

  .atk-comment > .atk-main > .atk-footer .atk-actions > span {
    color: var(--muted-foreground) !important;
    transition: color 200ms ease !important;
  }

  .atk-comment > .atk-main > .atk-footer .atk-actions > span:hover {
    color: var(--primary) !important;
  }

  .atk-send-btn {
    border-radius: 2rem !important;
    font-weight: 700 !important;
    box-shadow: 0 4px 12px oklch(from var(--primary) l c h / 0.2) !important;
  }

  .artalk .atk-pagination .atk-btn,
  .artalk .atk-list-load-more {
    border-radius: 999px !important;
    border-color: oklch(from var(--border) l c h / 0.6) !important;
    background: var(--card) !important;
    color: var(--muted-foreground) !important;
    transition:
      border-color 200ms ease,
      color 200ms ease,
      background-color 200ms ease !important;
  }

  .artalk .atk-pagination .atk-btn:hover,
  .artalk .atk-list-load-more:hover {
    border-color: oklch(from var(--primary) l c h / 0.3) !important;
    color: var(--primary) !important;
    background: oklch(from var(--primary) l c h / 0.04) !important;
  }
</style>
